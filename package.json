{
  "name": "temp_init",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepare": "nuxt prepare",
    "dev": "./dev.sh dev",
    "build": "pnpm build:public-discovery && node scripts/assert-content-images.ts && nuxt build",
    "build:content-images": "node scripts/build-content-images.ts",
    "build:search-index": "node scripts/build-search-index.ts",
    "build:public-discovery": "node scripts/build-public-discovery.ts",
    "build:public-artifacts": "node scripts/build-public-artifacts.ts",
    "test:e2e": "playwright test",
    "test": "vitest run --exclude 'tests/e2e/**'",
    "content:check": "node scripts/content-check.mjs",
    "lint": "eslint . --max-warnings=0",
    "lint:file": "eslint --fix --max-warnings=0",
    "format": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "generate": "./dev.sh generate",
    "preview": "nuxt preview"
  },
  "dependencies": {
    "@nuxt/ui": "^4.8.2",
    "@vueuse/core": "^14.3.0",
    "minisearch": "^7.2.0",
    "nuxt": "^4.4.8",
    "vue": "^3.5.24",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/image": "^1.10.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^9.39.4",
    "happy-dom": "^20.10.3",
    "postcss-nesting": "^13.0.2",
    "sharp": "^0.35.1",
    "typescript": "^6.0.3",
    "vitest": "^4.0.14",
    "vue-tsc": "^3.3.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "vue-demi"
    ]
  }
}
